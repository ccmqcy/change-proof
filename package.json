{
  "name": "change-proof",
  "version": "0.1.1",
  "description": "Turn a local git diff into a clean change, verification, and risk proof packet.",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "bin": {
    "change-proof": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/fix-bin-mode.mjs",
    "test": "npm run build && node --test tests/*.test.js",
    "verify": "npm test && npm run npm:preflight && npm run pack:dry && npm run verify:install",
    "prepack": "npm run build",
    "prepublishOnly": "npm run verify",
    "npm:preflight": "node scripts/npm-prepublish-check.mjs",
    "pack:dry": "npm pack --dry-run --registry https://registry.npmjs.org/",
    "publish:dry": "npm publish --dry-run --registry https://registry.npmjs.org/",
    "publish:manual": "npm publish --registry https://registry.npmjs.org/",
    "verify:install": "node scripts/verify-package-install.mjs",
    "start": "node dist/cli.js",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "keywords": [
    "git",
    "diff",
    "verification",
    "ai-coding",
    "code-review",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ccmqcy/change-proof.git"
  },
  "bugs": {
    "url": "https://github.com/ccmqcy/change-proof/issues"
  },
  "homepage": "https://github.com/ccmqcy/change-proof#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "^6.0.3"
  }
}
